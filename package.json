{
  "name": "prettier-plugin-verticalize",
  "version": "1.0.3-alpha.0",
  "description": "a Prettier plugin for vertically aligning your code.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "doc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/panruiplay/prettier-plugin-verticalize"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "test-tmp": "vitest run tests/tmp.test.ts",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "tsc --noEmit && eslint . --fix",
    "prepublishOnly": "npm run build",
    "prepare": "husky && patch-package"
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "vertical-align"
  ],
  "license": "MIT",
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@babel/parser": "7.29.7",
    "@babel/types": "7.29.7",
    "magic-string": "^0.30.21",
    "recast": "0.23.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.1.8"
  }
}
